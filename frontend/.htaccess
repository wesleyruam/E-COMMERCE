# ============================================================
#  Security .htaccess — Frontend E-Commerce
# ============================================================

Options -Indexes -MultiViews

# --- Forçar HTTPS (descomente em produção) ---
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Rewrite: URLs amigáveis ---
RewriteEngine On
RewriteBase /

# Ignorar arquivos e diretórios existentes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Rota de páginas
RewriteRule ^produto/([0-9]+)/?$  pages/product.php?id=$1 [L,QSA]
RewriteRule ^carrinho/?$          pages/cart.php           [L,QSA]
RewriteRule ^checkout/?$          pages/checkout.php       [L,QSA]
RewriteRule ^pedidos/?$           pages/orders.php         [L,QSA]
RewriteRule ^login/?$             pages/login.php          [L,QSA]
RewriteRule ^cadastro/?$          pages/register.php       [L,QSA]

# --- Bloquear acesso direto a arquivos sensíveis ---
<FilesMatch "\.(env|git|htpasswd|log|sql|sh|bak|conf|ini|json|lock|md|pem|key)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Bloquear acesso a arquivos ocultos (dotfiles)
<FilesMatch "^\.">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Permitir leitura do próprio .htaccess só pelo servidor
<Files ".htaccess">
    Order Allow,Deny
    Deny from all
</Files>

# --- Bloquear acesso direto a includes/ e config/ ---
RewriteRule ^(includes|config)/ - [F,L]

# --- Cabeçalhos de segurança HTTP ---
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'"
    # Remover header que expõe tecnologia
    Header unset X-Powered-By
    Header always unset Server
</IfModule>

# --- Proteger contra clickjacking e MIME sniffing ---
<IfModule mod_headers.c>
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

# --- Bloquear métodos HTTP não necessários ---
<LimitExcept GET POST>
    Deny from all
</LimitExcept>

# --- Bloquear strings maliciosas na URL (SQLi / XSS básico) ---
<IfModule mod_rewrite.c>
    RewriteCond %{QUERY_STRING} (union|select|insert|drop|delete|update|cast|exec|declare|benchmark|sleep) [NC]
    RewriteRule .* - [F,L]

    RewriteCond %{QUERY_STRING} (<|>|%3C|%3E|script|javascript|vbscript|onload|onerror) [NC]
    RewriteRule .* - [F,L]

    RewriteCond %{QUERY_STRING} (\.\./|\.\.\\) [NC]
    RewriteRule .* - [F,L]
</IfModule>

# --- Bloquear User-Agents maliciosos conhecidos ---
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_USER_AGENT} (nikto|sqlmap|nmap|masscan|zgrab|curl/7\.1|python-requests) [NC]
    RewriteRule .* - [F,L]
</IfModule>

# --- Limitar tamanho de upload ---
LimitRequestBody 5242880

# --- Cache para assets estáticos ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css             "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png            "access plus 1 year"
    ExpiresByType image/jpg            "access plus 1 year"
    ExpiresByType image/jpeg           "access plus 1 year"
    ExpiresByType image/gif            "access plus 1 year"
    ExpiresByType image/webp           "access plus 1 year"
    ExpiresByType image/svg+xml        "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# --- Compressão Gzip ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript
</IfModule>

# --- Página de erro personalizada ---
ErrorDocument 403 /pages/error.php?code=403
ErrorDocument 404 /pages/error.php?code=404
ErrorDocument 500 /pages/error.php?code=500
